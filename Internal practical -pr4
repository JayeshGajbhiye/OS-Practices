#include <stdio.h>
#include <unistd.h>
#include <sys/types.h>
#include <stdlib.h>

int main() {
    pid_t pid;

    pid = fork();   // Create child process

    if (pid < 0) {
        printf("Fork failed\n");
        return 1;
    }

    // Child Process
    else if (pid == 0) {
        printf("\n--- CHILD PROCESS ---\n");
        printf("Child PID: %d\n", getpid());
        printf("Parent PID (PPID): %d\n", getppid());

        sleep(5);  // Delay to show orphan case

        printf("\nAfter sleep (Orphan case):\n");
        printf("Child PID: %d\n", getpid());
        printf("New Parent PID (PPID): %d\n", getppid());

        exit(0);
    }

    // Parent Process
    else {
        printf("\n--- PARENT PROCESS ---\n");
        printf("Parent PID: %d\n", getpid());
        printf("Child PID: %d\n", pid);

        sleep(2);  // Parent exits early (child becomes orphan)

        printf("\nParent exiting...\n");

        // Comment below line to create Zombie Process
        // wait(NULL);

        exit(0);
    }

    return 0;
}
